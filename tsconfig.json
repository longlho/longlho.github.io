{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "#/*": ["./*"],
      "#tools/*": ["./tools/*"]
    },
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  }
}
